# ─── Hub API ────────────────────────────────────────────────
# URL del backend que expone los endpoints /api/admin/* (hoy pollar-backend,
# en el futuro platform/apps/hub-api). Sin trailing slash.
# Si no se setea, el admin no puede hacer ninguna llamada y muestra error.
NEXT_PUBLIC_HUB_API_URL=

# ─── Admin secret hacia el hub-api ──────────────────────────
# El backend valida el header X-Admin-Secret contra ADMIN_SECRET_KEY.
# Este valor se inyecta server-side desde los API routes del admin —
# nunca llega al browser.
ADMIN_HUB_SECRET=

# ─── Panel auth ─────────────────────────────────────────────
# Password única que el admin escribe en /admin/login.
# Generar con: openssl rand -hex 24
ADMIN_PANEL_PASSWORD=

# Secret para firmar la cookie HMAC del login. Si cambia, todas las
# sesiones existentes se invalidan automáticamente.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PANEL_COOKIE_SECRET=

# ─── Stellar (solo para links a Stellar Expert en el UI) ────
# TESTNET | MAINNET
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
